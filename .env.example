# Supabase — get from your project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side only — NEVER expose to browser.
# gs_outbox is RLS-deny-all with no policies, so WITHOUT this every GroundStream
# event insert is silently refused — supabase-js resolves the error rather than
# throwing, so nothing appears in the logs either.
SUPABASE_SERVICE_ROLE_KEY=

# ── GroundStream (see HANDOFF.md §5 and the /gs skill) ──────────────────────
# Master key for encrypting stored integration credentials at rest.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 64 hex characters. The app REFUSES TO START if missing, malformed, or the wrong
# length — there is deliberately no fallback, because a fail-open crypto default
# is indistinguishable from success at every layer above it.
# Rotating this makes every stored credential undecryptable; re-paste the key
# through /settings/groundstream afterwards.
GS_ENCRYPTION_KEY=

# Authorises the drain cron (vercel.json, */5 * * * * -> /api/cron/gs-drain).
# NOT OPTIONAL: without it the route returns 401 on every run and the outbox
# fills silently while every other indicator looks healthy. Any long random string.
CRON_SECRET=

# Optional env fallback for the GroundStream credential. Unnecessary once the
# connection is configured in-app at /settings/groundstream, which is preferred:
# one credential per organisation rather than one per deployment.
# GS_SOURCE must match the source registered in GroundStream CHARACTER-FOR-CHARACTER
# (case-sensitive, not trimmed on an unbound key).
GS_API_KEY=
GS_SOURCE=

# NOTE: GS_WORKSPACE no longer exists. The tenant is the organisation on the
# record (organisations.slug); a deployment-wide constant can only name one.

# ── Stripe ──────────────────────────────────────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_

# Webhook secret — from Stripe dashboard → Webhooks → your endpoint
# For local dev: stripe listen --forward-to localhost:3000/api/stripe/webhooks
STRIPE_WEBHOOK_SECRET=whsec_

# Your price IDs from Stripe dashboard → Products
NEXT_PUBLIC_STRIPE_PRICE_MONTHLY=price_
NEXT_PUBLIC_STRIPE_PRICE_YEARLY=price_

# ── Stripe Connect (set by Vibe Launchpad when provisioned via platform) ────
# Leave blank if running standalone with your own Stripe account
STRIPE_CONNECT_ACCOUNT_ID=
STRIPE_PLATFORM_FEE_PERCENT=

# ── App URL (used for redirect URLs) ────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
